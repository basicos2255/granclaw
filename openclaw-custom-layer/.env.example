# OpenClaw Connection
# REST API base URL (default: http://localhost:18789)
OPENCLAW_BASE_URL=http://localhost:18789
# WebSocket URL for RPC (FIX 040: official endpoint with /__openclaw__ prefix)
# Default: ws://localhost:18789/__openclaw__/ws
OPENCLAW_WS_URL=ws://localhost:18789/__openclaw__/ws
# API Key for authentication (gateway.auth.token from openclaw.json)
# FIX 040: This token is sent as Authorization: Bearer header in WS upgrade
OPENCLAW_API_KEY=

# WebSocket Client Identity (FIX 034 - OFICIAL)
# Must match OpenClaw Gateway schema constants
# Default: gateway-client (valor oficial para backend confiable)
OPENCLAW_WS_CLIENT_ID=gateway-client
# Default: backend (valor oficial para backend confiable)
OPENCLAW_WS_CLIENT_MODE=backend
# Optional: comma-separated variants to try (format: id:mode,id:mode)
OPENCLAW_WS_CLIENT_VARIANTS=gateway-client:backend,cli:operator

# Application Ports
APP_PORT=3001
WEB_PORT=5173
VITE_API_URL=http://localhost:3001

# Environment
NODE_ENV=development
