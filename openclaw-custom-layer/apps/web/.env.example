# GranClaw Web Frontend Environment Variables
# P2.2: API Base URL & Runtime State Fetch Fix
# P5.2: Config consistency - unified naming

# API Base URL - Backend server
# Default: http://localhost:3001
VITE_API_BASE_URL=http://localhost:3001

# WebSocket Base URL - For real-time updates
# Default: ws://localhost:3001
VITE_WS_BASE_URL=ws://localhost:3001

# DEPRECATED (P5.2): Use VITE_API_BASE_URL and VITE_WS_BASE_URL instead
# VITE_API_URL - deprecated, use VITE_API_BASE_URL
# VITE_WS_URL - deprecated, use VITE_WS_BASE_URL
# VITE_API_PORT - deprecated, use VITE_WS_BASE_URL
