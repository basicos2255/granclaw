{
  "name": "granclaw",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "check": "npm run check --workspaces --if-present",
    "dev:api": "npm run dev --workspace=@granclaw/api",
    "dev:web": "npm run dev --workspace=@granclaw/web -- --host 0.0.0.0",
    "start:api": "npm run start --workspace=@granclaw/api",
    "start:web": "npm run preview --workspace=@granclaw/web -- --host 0.0.0.0",
    "dev": "sh ./scripts/granclaw-dev.sh start",
    "dev:stop": "sh ./scripts/granclaw-dev.sh stop",
    "dev:restart": "sh ./scripts/granclaw-dev.sh restart",
    "dev:status": "sh ./scripts/granclaw-dev.sh status",
    "dev:logs": "sh ./scripts/granclaw-dev.sh logs"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
